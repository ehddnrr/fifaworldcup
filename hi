<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FreshKeeper AI - AI 기반 냉장고 식재료 관리 & 맞춤 레시피</title>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap" rel="stylesheet">
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <!-- Stylesheet -->
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <!-- AUTH VIEW -->
  <div id="auth-view" class="auth-container">
    <div class="auth-card glass-card">
      <div class="auth-header">
        <div class="logo-area">
          <div class="logo-icon">🍏</div>
          <h1>FreshKeeper <span class="gradient-text">AI</span></h1>
        </div>
        <p class="auth-subtitle">AI 기반 냉장고 식재료 관리 및 맞춤 레시피 추천</p>
      </div>
      
      <form id="auth-form" class="auth-form">
        <div class="form-group">
          <label for="login-id">아이디</label>
          <div class="input-wrapper">
            <i data-lucide="user"></i>
            <input type="text" id="login-id" placeholder="id@example.com 또는 아이디 입력" required>
          </div>
        </div>
        <div class="form-group">
          <label for="login-pw">비밀번호</label>
          <div class="input-wrapper">
            <i data-lucide="lock"></i>
            <input type="password" id="login-pw" placeholder="••••••••" required>
          </div>
        </div>
        <div class="auth-options">
          <label class="checkbox-container">
            <input type="checkbox" id="remember-me" checked>
            <span class="checkmark"></span>
            로그인 상태 유지
          </label>
          <a href="#" id="btn-forgot-pw" class="forgot-link">비밀번호 재설정</a>
        </div>
        <button type="submit" class="btn-primary auth-submit-btn">로그인</button>
      </form>
      <div class="auth-divider">
        <span>또는 간편 로그인</span>
      </div>
      <div class="social-login-group">
        <button id="btn-kakao-login" class="btn-social btn-kakao" type="button">
          <span class="social-icon">💬</span>
          카카오톡으로 시작하기
        </button>
        <button id="btn-google-login" class="btn-social btn-google" type="button">
          <svg class="social-svg" viewBox="0 0 24 24" width="18" height="18">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22-.03-.63z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Google 계정으로 시작하기
        </button>
      </div>
    </div>
  </div>
  <!-- PASSWORD RESET MODAL -->
  <div id="reset-pw-modal" class="modal-overlay hidden">
    <div class="modal-content glass-card width-sm">
      <div class="modal-header">
        <h3>비밀번호 재설정 이메일 발송</h3>
        <button class="btn-close-modal" id="btn-close-reset-pw"><i data-lucide="x"></i></button>
      </div>
      <div class="modal-body">
        <p class="modal-desc">가입하신 이메일 주소를 입력하시면 비밀번호를 재설정할 수 있는 링크를 보내드립니다.</p>
        <div class="form-group margin-top-md">
          <label for="reset-email">이메일 주소</label>
          <div class="input-wrapper">
            <i data-lucide="mail"></i>
            <input type="email" id="reset-email" placeholder="example@email.com">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" id="btn-cancel-reset-pw">취소</button>
        <button id="btn-send-reset-email" class="btn-primary">이메일 발송</button>
      </div>
    </div>
  </div>
  <!-- MAIN APP VIEW -->
  <div id="main-view" class="app-layout hidden">
    <!-- Sidebar Navigation -->
    <aside class="sidebar glass-card">
      <div class="sidebar-brand">
        <span class="logo-icon">🍏</span>
        <h2>FreshKeeper <span class="gradient-text">AI</span></h2>
      </div>
      
      <div class="user-profile-summary">
        <div class="avatar">U</div>
        <div class="user-info">
          <span class="user-name" id="display-user-name">사용자 님</span>
          <span class="user-status"><span class="badge badge-success">Premium</span></span>
        </div>
      </div>
      <nav class="sidebar-nav">
        <button class="nav-item active" data-target="panel-fridge">
          <i data-lucide="refrigerator"></i>
          <span>내 냉장고</span>
        </button>
        <button class="nav-item" data-target="panel-ocr">
          <i data-lucide="scan-line"></i>
          <span>영수증 인식 등록</span>
        </button>
        <button class="nav-item" data-target="panel-recipe">
          <i data-lucide="chef-hat"></i>
          <span>AI 맞춤 레시피</span>
        </button>
      </nav>
      <div class="sidebar-footer">
        <button id="btn-settings" class="nav-item btn-side-action">
          <i data-lucide="settings"></i>
          <span>설정 (Gemini API)</span>
        </button>
        <button id="btn-logout" class="nav-item btn-side-action logout-btn">
          <i data-lucide="log-out"></i>
          <span>로그아웃</span>
        </button>
      </div>
    </aside>
    <!-- Main Content Area -->
    <main class="main-content">
      
      <!-- Top Sticky Navigation / Banner -->
      <header class="app-header glass-card">
        <div class="header-welcome">
          <h1 id="header-title">내 냉장고 관리</h1>
          <p id="header-subtitle" class="header-desc">신선하게 식재료를 보관하고 낭비를 줄이세요.</p>
        </div>
        
        <div class="header-actions">
          <!-- Notification Bell and Badge -->
          <div class="notification-trigger" id="btn-notification-center">
            <i data-lucide="bell"></i>
            <span class="notification-badge hidden" id="banner-noti-count">0</span>
          </div>
          <!-- Clock/Status Sim button -->
          <button class="btn-time-sim" id="btn-trigger-morning-alarm">
            <i data-lucide="alarm-clock"></i>
            <span>아침 9시 알림 시뮬레이션</span>
          </button>
        </div>
      </header>
      <!-- Expiring Notification Bar -->
      <div id="expiration-alert-banner" class="alert-banner hidden">
        <div class="alert-content">
          <span class="alert-icon">⚠️</span>
          <span class="alert-text" id="expiration-alert-text">유통기한이 3일 이하로 남은 식재료가 있습니다!</span>
        </div>
        <button class="btn-alert-action" id="btn-banner-action">확인하기</button>
      </div>
      <!-- PANEL: MY FRIDGE -->
      <div id="panel-fridge" class="content-panel active">
        <!-- Fridge Summary Stats -->
        <div class="stats-row">
          <div class="stat-card glass-card">
            <div class="stat-icon icon-total"><i data-lucide="layers"></i></div>
            <div class="stat-info">
              <span class="stat-label">전체 식재료</span>
              <h3 class="stat-val" id="stat-total-count">0</h3>
            </div>
          </div>
          <div class="stat-card glass-card warning">
            <div class="stat-icon icon-urgent"><i data-lucide="alert-triangle"></i></div>
            <div class="stat-info">
              <span class="stat-label">유통기한 임박 (D-3)</span>
              <h3 class="stat-val" id="stat-urgent-count">0</h3>
            </div>
          </div>
          <div class="stat-card glass-card success">
            <div class="stat-icon icon-success"><i data-lucide="check-circle-2"></i></div>
            <div class="stat-info">
              <span class="stat-label">소진한 식재료 수</span>
              <h3 class="stat-val" id="stat-depleted-count">0</h3>
            </div>
          </div>
        </div>
        <!-- Filter and Search Bar -->
        <div class="filter-bar glass-card">
          <div class="search-box">
            <i data-lucide="search"></i>
            <input type="text" id="fridge-search" placeholder="식재료 검색...">
          </div>
          
          <div class="filter-actions">
            <div class="select-wrapper">
              <select id="fridge-sort-select">
                <option value="expiry-asc">유통기한 임박순</option>
                <option value="expiry-desc">유통기한 여유순</option>
                <option value="name-asc">이름 가나다순</option>
                <option value="reg-desc">최근 등록순</option>
              </select>
              <i data-lucide="chevron-down"></i>
            </div>
            
            <button class="btn-primary" id="btn-add-ingredient-manual">
              <i data-lucide="plus"></i>
              <span>식재료 직접 추가</span>
            </button>
          </div>
        </div>
        <!-- Categories horizontal list -->
        <div class="category-tabs" id="fridge-category-tabs">
          <button class="category-tab active" data-category="ALL">전체</button>
          <button class="category-tab" data-category="vegetable">🥦 채소</button>
          <button class="category-tab" data-category="meat">🥩 육류</button>
          <button class="category-tab" data-category="seafood">🐟 해산물</button>
          <button class="category-tab" data-category="fruit">🍎 과일</button>
          <button class="category-tab" data-category="dairy">🥛 유제품</button>
          <button class="category-tab" data-category="processed">🥫 가공/냉동</button>
          <button class="category-tab" data-category="other">📦 기타</button>
        </div>
        <!-- Ingredients Grid -->
        <div class="ingredients-grid-container">
          <div class="ingredients-grid" id="ingredients-grid">
            <!-- Dynamic Ingredients Cards -->
          </div>
          <!-- Empty State -->
          <div id="fridge-empty-state" class="empty-state hidden">
            <div class="empty-icon">🍽️</div>
            <h4>냉장고가 비어 있습니다</h4>
            <p>직접 입력하거나 영수증 사진을 스캔하여 식재료를 추가해 보세요!</p>
            <div class="empty-actions">
              <button class="btn-primary" id="btn-empty-add">식재료 등록</button>
              <button class="btn-secondary" id="btn-empty-scan">영수증 스캔</button>
            </div>
          </div>
        </div>
      </div>
      <!-- PANEL: RECEIPT OCR -->
      <div id="panel-ocr" class="content-panel hidden">
        <div class="grid-col-2">
          <!-- OCR Upload / Camera Area -->
          <div class="glass-card panel-left-content">
            <div class="section-title">
              <i data-lucide="scan-line"></i>
              <h3>영수증 등록</h3>
            </div>
            <p class="panel-desc">구매하신 영수증을 카메라로 촬영하거나 이미지를 업로드하시면 식재료를 자동으로 추출합니다.</p>
            
            <div class="ocr-upload-zone" id="ocr-drop-zone">
              <i data-lucide="image" class="upload-icon"></i>
              <p class="upload-main-text">영수증 이미지를 여기에 드래그하거나 클릭하여 업로드</p>
              <p class="upload-sub-text">지원 형식: JPG, PNG, WebP (최대 10MB)</p>
              <input type="file" id="ocr-file-input" accept="image/*" class="hidden">
              <button class="btn-secondary btn-sm" id="btn-select-ocr-file">파일 선택</button>
            </div>
            <div class="sample-receipt-section">
              <h4>빠른 테스트를 위한 샘플 영수증 선택</h4>
              <p class="sample-desc">아래의 샘플 영수증을 클릭하면 실제 이미지 업로드 및 OCR 텍스트 분석 과정이 시뮬레이션됩니다.</p>
              <div class="sample-buttons">
                <button class="btn-sample" id="btn-sample-emart">🛒 이마트 영수증 (소고기, 버섯, 양파 등)</button>
                <button class="btn-sample" id="btn-sample-organic">🥬 유기농 생협 영수증 (달걀, 우유, 갈치 등)</button>
              </div>
            </div>
          </div>
          <!-- OCR Processing & Verification Area -->
          <div class="glass-card panel-right-content">
            <div class="section-title">
              <i data-lucide="check-square"></i>
              <h3>추출 및 확인 결과</h3>
            </div>
            
            <!-- Idle Screen -->
            <div id="ocr-idle-screen" class="ocr-status-screen">
              <div class="status-graphic">📁</div>
              <p>영수증을 업로드하거나 좌측 샘플 영수증을 클릭하시면 식재료 분석이 시작됩니다.</p>
            </div>
            <!-- Scanning Loading Screen -->
            <div id="ocr-scanning-screen" class="ocr-status-screen hidden">
              <div class="scanner-laser"></div>
              <div class="status-graphic spinner"></div>
              <h4 id="ocr-scan-step">이미지 텍스트 추출 중...</h4>
              <p class="scan-detail-log" id="ocr-scan-log">영수증에서 식재료 이름과 수량을 필터링하는 중입니다.</p>
            </div>
            <!-- Review Screen -->
            <div id="ocr-review-screen" class="ocr-review-content hidden">
              <div class="scan-preview-header">
                <div class="preview-badge"><i data-lucide="check"></i> 텍스트 분석 완료</div>
                <span class="expiry-calc-hint">💡 유통기한은 등록일 기준 <strong>+7일</strong>로 자동 계산되었습니다. 필요 시 수정이 가능합니다.</span>
              </div>
              <!-- List of extracted items -->
              <div class="extracted-items-list" id="extracted-items-container">
                <!-- Extracted row items -->
              </div>
              <div class="review-actions">
                <button class="btn-secondary" id="btn-ocr-cancel">다시 촬영/취소</button>
                <button class="btn-primary" id="btn-ocr-confirm-add">
                  <i data-lucide="check-circle"></i>
                  <span>식재료 냉장고에 등록 (<span id="ocr-selected-count">0</span>개)</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- PANEL: RECIPE SEARCH & RECOMMENDATION -->
      <div id="panel-recipe" class="content-panel hidden">
        <div class="grid-col-2">
          <!-- Recipe Filters and Ingredient Selection -->
          <div class="glass-card">
            <div class="section-title">
              <i data-lucide="chef-hat"></i>
              <h3>AI 레시피 요청 설정</h3>
            </div>
            <p class="panel-desc">냉장고에서 요리에 사용할 재료들을 선택해 주세요. 유통기한이 임박한 식재료는 자동으로 사전 선택됩니다.</p>
            <form id="recipe-recommendation-form" class="recipe-form" onsubmit="event.preventDefault();">
              <!-- Selectable Ingredients Grid -->
              <div class="form-group">
                <label>재료 선택 (<span id="recipe-selected-ingredients-count">0</span>개 선택됨)</label>
                <div class="recipe-ingredients-selector-container">
                  <div class="recipe-ingredients-selector" id="recipe-ingredients-selector-grid">
                    <!-- Checkbox items for ingredients in fridge -->
                  </div>
                  <div id="recipe-selector-empty" class="recipe-selector-empty hidden">
                    냉장고에 선택할 수 있는 식재료가 없습니다. 먼저 식재료를 등록하세요!
                  </div>
                </div>
              </div>
              <!-- Cook Time & Difficulty -->
              <div class="grid-col-2 margin-top-sm">
                <div class="form-group">
                  <label for="recipe-cook-time">최대 조리 시간</label>
                  <div class="select-wrapper">
                    <select id="recipe-cook-time">
                      <option value="10">⏱️ 10분 이내 (간편식)</option>
                      <option value="20" selected>⏱️ 20분 이내 (일반 조리)</option>
                      <option value="30">⏱️ 30분 이내 (숙련 조리)</option>
                    </select>
                    <i data-lucide="chevron-down"></i>
                  </div>
                </div>
                
                <div class="form-group">
                  <label for="recipe-difficulty">조리 난이도</label>
                  <div class="select-wrapper">
                    <select id="recipe-difficulty">
                      <option value="easy" selected>🐣 하 (누구나 가능)</option>
                      <option value="medium">🍳 중 (기본 칼질 필요)</option>
                      <option value="hard">🔥 상 (고급 화력 조절)</option>
                    </select>
                    <i data-lucide="chevron-down"></i>
                  </div>
                </div>
              </div>
              <!-- Submit button -->
              <button type="button" class="btn-primary btn-full-width margin-top-md" id="btn-generate-recipes">
                <i data-lucide="sparkles"></i>
                <span>AI 맞춤 레시피 생성 시작</span>
              </button>
            </form>
          </div>
          <!-- Recipe Recommendations Results -->
          <div class="glass-card">
            <div class="section-title">
              <i data-lucide="sparkles"></i>
              <h3>추천 레시피 목록</h3>
            </div>
            <!-- Idle State -->
            <div id="recipe-idle-state" class="recipe-results-state">
              <div class="results-graphic">🍳</div>
              <p>좌측에서 식재료와 설정을 완료하고 레시피 생성 버튼을 누르면 인공지능이 최적의 메뉴를 매칭해 드립니다.</p>
            </div>
            <!-- Loading State -->
            <div id="recipe-loading-state" class="recipe-results-state hidden">
              <div class="recipe-loader"></div>
              <h4 id="recipe-loading-title">AI 맞춤 레시피 조합 중...</h4>
              <p id="recipe-loading-desc">선택된 식재료(우선순위: 유통기한 임박)를 활용해 영양 밸런스와 조리 조건을 만족하는 레시피를 분석하고 있습니다.</p>
            </div>
            <!-- Recipe List -->
            <div id="recipe-results-list" class="recipe-list hidden">
              <!-- Dynamically populated recipe summary cards -->
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
  <!-- INGREDIENT MANUAL ADD/EDIT MODAL -->
  <div id="ingredient-modal" class="modal-overlay hidden">
    <div class="modal-content glass-card width-md">
      <div class="modal-header">
        <h3 id="ingredient-modal-title">식재료 추가</h3>
        <button class="btn-close-modal" id="btn-close-ingredient-modal"><i data-lucide="x"></i></button>
      </div>
      
      <form id="ingredient-form" class="modal-body" onsubmit="event.preventDefault();">
        <input type="hidden" id="edit-ingredient-id">
        
        <div class="form-group">
          <label for="ing-name">식재료 이름</label>
          <input type="text" id="ing-name" placeholder="예: 무농약 양파" required>
        </div>
        <div class="grid-col-2">
          <div class="form-group">
            <label for="ing-category">카테고리</label>
            <div class="select-wrapper">
              <select id="ing-category" required>
                <option value="vegetable" selected>🥦 채소</option>
                <option value="meat">🥩 육류</option>
                <option value="seafood">🐟 해산물</option>
                <option value="fruit">🍎 과일</option>
                <option value="dairy">🥛 유제품</option>
                <option value="processed">🥫 가공/냉동</option>
                <option value="other">📦 기타</option>
              </select>
              <i data-lucide="chevron-down"></i>
            </div>
          </div>
          
          <div class="form-group">
            <label for="ing-qty">수량</label>
            <div class="qty-counter">
              <button type="button" class="btn-qty-adj" id="btn-qty-dec"><i data-lucide="minus"></i></button>
              <input type="number" id="ing-qty" value="1" min="1" required>
              <button type="button" class="btn-qty-adj" id="btn-qty-inc"><i data-lucide="plus"></i></button>
            </div>
